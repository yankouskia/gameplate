{
  "name": "gameplate",
  "version": "2.0.1",
  "description": "Tiny, zero-dependency, fully-typed TypeScript framework for browser & headless games — state, loop, input, scenes. Bring any renderer.",
  "keywords": [
    "game",
    "game-engine",
    "game-framework",
    "game-loop",
    "state-machine",
    "fsm",
    "typescript",
    "headless",
    "canvas",
    "webgl",
    "browser",
    "tiny",
    "zero-dependencies",
    "esm",
    "renderer-agnostic"
  ],
  "homepage": "https://yankouskia.github.io/gameplate/",
  "bugs": {
    "url": "https://github.com/yankouskia/gameplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yankouskia/gameplate.git"
  },
  "license": "MIT",
  "author": {
    "name": "Alex Yankouski",
    "email": "alex.yankouski@gmail.com",
    "url": "https://github.com/yankouskia"
  },
  "funding": "https://github.com/sponsors/yankouskia",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .turbo node_modules/.cache",
    "dev": "tsup --watch",
    "docs": "typedoc",
    "docs:serve": "pnpm docs && npx serve docs/api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm clean && pnpm install && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm pkg:validate",
    "pkg:validate": "publint && node scripts/attw.mjs",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.6.1",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.4.2",
    "publint": "^0.3.0",
    "simple-git-hooks": "^2.11.1",
    "size-limit": "^11.1.6",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.0",
    "typedoc-material-theme": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "size-limit": [
    {
      "name": "core (esm)",
      "path": "dist/index.js",
      "limit": "4 kB",
      "import": "*"
    },
    {
      "name": "core (cjs)",
      "path": "dist/index.cjs",
      "limit": "5 kB"
    }
  ],
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
